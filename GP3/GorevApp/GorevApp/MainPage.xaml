<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:GorevApp"
             x:Class="GorevApp.MainPage"
             Title="Görev Listesi">

    <CollectionView x:Name="TasksCollection" SelectionMode="None">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="local:TodoItem">
<SwipeView>
    <SwipeView.RightItems>
        <SwipeItems>
            <SwipeItem Text="Düzenle" BackgroundColor="DarkBlue" 
                        Invoked="OnEditInvoked" CommandParameter="{Binding .}"/>
            <SwipeItem Text="Sil" BackgroundColor="Red" IsDestructive="True"
                        Invoked="OnDeleteInvoked" CommandParameter="{Binding .}"/>
        </SwipeItems>
    </SwipeView.RightItems>

    <Grid Padding="15">
        <HorizontalStackLayout Spacing="10">
            <CheckBox IsChecked="{Binding IsCompleted}" />
            <Label Text="{Binding Title}" VerticalOptions="Center" FontSize="18"/>
        </HorizontalStackLayout>
    </Grid>
</SwipeView>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
