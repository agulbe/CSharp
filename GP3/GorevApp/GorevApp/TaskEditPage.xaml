<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="GorevApp.TaskEditPage"
    Title="Görev Detayı">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Kaydet" Clicked="OnSaveClicked" />
        <ToolbarItem Text="Vazgeç" Clicked="OnCancelClicked" />
    </ContentPage.ToolbarItems>

    <VerticalStackLayout Padding="20" Spacing="15">
        <Entry x:Name="TitleEntry" Placeholder="Görev Adı" />
        <Picker x:Name="CategoryPicker" Title="Kategori Seçin">
            <Picker.Items>
                <x:String>İş</x:String>
                <x:String>Kişisel</x:String>
                <x:String>Acil</x:String>
            </Picker.Items>
        </Picker>
        <DatePicker x:Name="DueDatePicker" />
    </VerticalStackLayout>

</ContentPage>